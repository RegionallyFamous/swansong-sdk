{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://regionallyfamous.dev/swansong/schema/author-palette.schema.json",
  "title": "SwanSong palette and mono mapping authoring document v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "colors", "monoMapping", "transparentIndex"],
  "properties": {
    "schema": {"const": "swansong-author-palette-v1"},
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"},
    "colors": {
      "type": "array", "minItems": 1, "maxItems": 16,
      "items": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"}
    },
    "monoMapping": {
      "type": "array", "minItems": 1, "maxItems": 16,
      "items": {"type": "integer", "minimum": 0, "maximum": 3}
    },
    "transparentIndex": {"type": ["integer", "null"], "minimum": 0, "maximum": 15}
  }
}
