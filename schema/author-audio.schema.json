{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://regionallyfamous.dev/swansong/schema/author-audio.schema.json",
  "title": "SwanSong audio pattern and instrument authoring document v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "framesPerRowQ8", "loop", "instruments", "rows"],
  "properties": {
    "schema": {"const": "swansong-author-audio-v1"},
    "id": {"$ref": "#/$defs/id"},
    "framesPerRowQ8": {"type": "integer", "minimum": 1, "maximum": 65535},
    "loop": {"type": "boolean"},
    "instruments": {
      "type": "array", "minItems": 1, "maxItems": 16,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "wave", "attack", "release"],
        "properties": {
          "id": {"$ref": "#/$defs/id"},
          "wave": {"type": "array", "minItems": 16, "maxItems": 16, "items": {"type": "integer", "minimum": 0, "maximum": 15}},
          "attack": {"type": "integer", "minimum": 0, "maximum": 255},
          "release": {"type": "integer", "minimum": 0, "maximum": 255}
        }
      }
    },
    "rows": {
      "type": "array", "minItems": 1, "maxItems": 65535,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "channels"],
        "properties": {
          "id": {"$ref": "#/$defs/id"},
          "channels": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"$ref": "#/$defs/command"}}
        }
      }
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"},
    "command": {
      "type": "object", "additionalProperties": false,
      "required": ["note", "instrument", "volume"],
      "properties": {
        "note": {"oneOf": [{"type": "integer", "minimum": 0, "maximum": 127}, {"enum": ["hold", "off"]}]},
        "instrument": {"anyOf": [{"$ref": "#/$defs/id"}, {"const": "hold"}]},
        "volume": {"oneOf": [{"type": "integer", "minimum": 0, "maximum": 15}, {"const": "hold"}]}
      }
    }
  }
}
