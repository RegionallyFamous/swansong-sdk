{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://regionallyfamous.dev/swansong/schema/scenario-outcome-contract.schema.json",
  "title": "SwanSong structured scenario outcome contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema"],
  "properties": {
    "schema": {"const": "swan-scenario-outcome-contract-v1"},
    "requireCompleteTrace": {"type": "boolean", "default": false},
    "traceSHA256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "final": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scene": {"type": "integer", "minimum": 0, "maximum": 254},
        "ending": {"type": "integer", "minimum": 0, "maximum": 255},
        "progress": {"type": "integer", "minimum": 0, "maximum": 65535},
        "progressAtLeast": {"type": "integer", "minimum": 0, "maximum": 65535},
        "progressAtMost": {"type": "integer", "minimum": 0, "maximum": 65535},
        "stateHash": {"type": "integer", "minimum": 0, "maximum": 4294967295}
      }
    },
    "reset": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expectation": {"enum": ["any", "none", "required", "exactly-one"]},
        "scene": {"type": "integer", "minimum": 0, "maximum": 254},
        "ending": {"type": "integer", "minimum": 0, "maximum": 255},
        "progress": {"type": "integer", "minimum": 0, "maximum": 65535},
        "stateHash": {"type": "integer", "minimum": 0, "maximum": 4294967295},
        "sessionTick": {"type": "integer", "minimum": 0, "maximum": 4294967295}
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expectation": {"enum": ["any", "audible", "silent"]},
        "markerMask": {"type": "integer", "minimum": 1, "maximum": 65535},
        "peakThreshold": {"type": "number", "minimum": 0}
      }
    }
  }
}
